# Copy to .env only for local tooling — never commit real secrets.
# agent-wizard reads policy from the environment in CI (see README).

# Comma-separated source names allowed by `agent-wizard ci-check`
# AGENT_WIZARD_ALLOWED_SOURCES=my-team,community

# Minimum agentskills.yaml schemaVersion required by ci-check
# AGENT_WIZARD_MIN_SCHEMA_VERSION=1

# Optional: cache directory override (CLI cache)
# XDG_CACHE_HOME=

# npm wrapper (@aryaashish/agent-wizard) — see npm/agent-wizard/README.md
# AGENT_WIZARD_VERSION=
# AGENT_WIZARD_REPO=
# AGENT_WIZARD_CACHE_DIR=

# curl install.sh — binary destination directory
# INSTALL_DIR=
